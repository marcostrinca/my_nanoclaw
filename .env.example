# === NanoClaw Configuration ===
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Identity ---
ASSISTANT_NAME=Yume

# --- Timezone (IANA format) ---
# TZ=America/Sao_Paulo

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Set to true if Telegram is the only inbound channel (no WhatsApp)
TELEGRAM_ONLY=true

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Default Slack channel for cross-channel messaging (format: slack:CXXXXXXXXXX)
SLACK_DEFAULT_CHANNEL=

# --- WhatsApp (optional, for send-only) ---
# WHATSAPP_OWNER_JID=5511999999999@s.whatsapp.net

# --- Google Drive (optional) ---
# OAuth credentials go in ~/.gdrive-mcp/gcp-oauth.keys.json
# See docs/GDRIVE_SETUP.md for instructions

# --- Ollama (optional) ---
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_ADMIN_TOOLS=false
